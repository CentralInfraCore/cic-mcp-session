# Local runtime env file (job: session-runtime-env-unification-001) — real
# DB credentials live ONLY here, never committed. See session.env.example
# for the committed template (placeholder values only) and
# session_store/runtime_env.py for the loader.
/session.env

# Sandbox ingest outbox (job: session-ingest-hook-sandboxed-001) — the 6
# hooks' disposable NDJSON sink + byte-offset store. Runtime-only, never a
# committed artifact. The default sink lives here when
# CIC_SESSION_INGEST_OUTBOX is unset.
/hooks/.sandbox-outbox/
