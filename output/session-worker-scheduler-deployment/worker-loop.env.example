# worker-loop.env.example
#
# DOCUMENTED DEPLOYMENT ARTIFACT — NOT DEPLOYED, NOT a real credential file.
# Example EnvironmentFile referenced by cic-session-worker-loop.service
# (EnvironmentFile=-/etc/cic-session/worker-loop.env). Copy to that path and
# fill in real values ONLY once a live production Postgres instance for
# cic-mcp-session actually exists — it does not as of this job.

SESSION_STORE_PG_HOST=localhost
SESSION_STORE_PG_PORT=5432
SESSION_STORE_PG_DB=cic_session
SESSION_STORE_PG_USER=cic_session_worker
SESSION_STORE_PG_PASSWORD=changeme
