# session.env.example
#
# Template for the shared runtime env file consumed by ALL cic-mcp-session
# DB-config consumers — session_store/worker_loop.py, mcp-server/
# session_server.py — and, via SESSION_ENV_FILE / the same five keys, the
# cic-mcp-gateway session-adapter subprocess launch path
# (gateway_core/compile_context.py SessionServerLaunchConfig).
#
# Job: session-runtime-env-unification-001
#
# Usage:
#   cp session.env.example session.env
#   # edit session.env with REAL values — session.env is .gitignore'd,
#   # NEVER commit it (see .gitignore "Local runtime env file" entry).
#
# Resolution (see session_store/runtime_env.py module docstring):
#   1. SESSION_ENV_FILE env var, if set, points at an arbitrary path.
#   2. Otherwise <repo_root>/session.env, if it exists.
#   3. Otherwise: no-op — SessionStoreConfig.from_env()'s own existing
#      defaults (localhost/5432/postgres/postgres/'', or PG* fallback)
#      apply unchanged.
#
# These are the SAME five keys session_store/envelope_writer.py:
# SessionStoreConfig.from_env() already reads — this file does not
# introduce any new env var name, only a shared FILE to put them in.

SESSION_STORE_PG_HOST=localhost
SESSION_STORE_PG_PORT=5432
SESSION_STORE_PG_DB=cic_session
SESSION_STORE_PG_USER=cic_session
SESSION_STORE_PG_PASSWORD=changeme
